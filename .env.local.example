# Copy this file to .env.local and fill in your Vercel KV / Upstash credentials.
# NEVER commit .env.local — it is listed in .gitignore.

KV_URL="rediss://default:<your-upstash-password>@<your-upstash-host>.upstash.io:6379"
REDIS_URL="rediss://default:<your-upstash-password>@<your-upstash-host>.upstash.io:6379"
KV_REST_API_URL="https://<your-upstash-host>.upstash.io"
KV_REST_API_TOKEN="<your-upstash-rest-token>"
KV_REST_API_READ_ONLY_TOKEN="<your-upstash-read-only-token>"
